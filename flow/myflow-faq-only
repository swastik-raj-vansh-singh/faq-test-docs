        const faqValid = {{codeNode_validate_faqs.output.valid}};
        const faqError = {{codeNode_validate_faqs.output.error}};
        const faqCount = {{codeNode_validate_faqs.output.faq_count}};
        const skipCheck = {{codeNode_length_check.output.skip}};
        const skipReason = {{codeNode_length_check.output.reason}};
        const filePath = {{codeNode_parse_input.output.file_path}};
        const title = {{codeNode_parse_input.output.title}};

        if (skipCheck) {
          output = {
            status: "skipped",
            reason: skipReason,
            file_path: filePath,
            title: title,
            faq_count: 0,
            faqs: [],
            validation_error: ""
          };
        } else if (!faqValid) {
          output = {
            status: "error",
            reason: "FAQ validation failed",
            file_path: filePath,
            title: title,
            faq_count: 0,
            faqs: [],
            validation_error: faqError
          };
        } else {
          output = {
            status: "success",
            reason: "",
            file_path: filePath,
            title: title,
            faq_count: faqCount,
            faqs: faqs,
            validation_error: ""
          };
        }
