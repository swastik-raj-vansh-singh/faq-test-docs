  - nodeId: codeNode_validate_faqs
    nodeType: codeNode
    nodeName: Validate FAQs
    values:
      code: |-
        const faqs = {{InstructorLLMNode_faq_gen.output.faqs}};
        let valid = true;
        let errorMsg = "";

        try {
          if (!Array.isArray(faqs)) {
            throw new Error("Expected an array, got: " + typeof faqs);
          }

          if (faqs.length < 5 || faqs.length > 10) {
            throw new Error("Expected 5-10 FAQs, got: " + faqs.length);
          }

          for (const item of faqs) {
            if (!item.question || typeof item.question !== "string") {
              throw new Error("FAQ item missing question: " + JSON.stringify(item));
            }
            if (!item.answer || typeof item.answer !== "string") {
              throw new Error("FAQ item missing answer: " + JSON.stringify(item));
            }
            if (item.question.length < 10) {
              throw new Error("Question too short: " + item.question);
            }
            if (item.answer.split(" ").length < 20) {
              throw new Error("Answer too short (< 20 words): " + item.answer.substring(0, 80) + "...");
            }
          }
        } catch (e) {
          valid = false;
          errorMsg = e.message || String(e);
        }

        output = {
          valid: valid,
          error: errorMsg,
          faqs: valid ? faqs : [],
          faq_count: valid ? faqs.length : 0
        };
    modes: {}
    needs:
