  - nodeId: codeNode_parse_input
    nodeType: codeNode
    nodeName: Parse Input
    values:
      code: >-
        const raw = {{triggerNode_1.output}};

        const filePath = raw.path || raw.file_path || raw.filename || "";

        const markdown = raw.markdown || raw.content || raw.file_content || "";

        const fileName = filePath.split("/").pop().replace(/\.mdx?$/, "");


        let title = "";

        let cleanContent = markdown;


        const fmMatch = markdown.match(/^---\n([\s\S]*?)\n---/);

        if (fmMatch) {
          const tm = fmMatch[1].match(/title:\s*(.+)/);
          if (tm) title = tm[1].trim().replace(/^["']|["']$/g, "");
          cleanContent = markdown.slice(fmMatch[0].length).trim();
        }

        if (!title) {
          const h1 = cleanContent.match(/^#\s+(.+)/m);
          if (h1) title = h1[1].trim();
        }


        let stripped = cleanContent.replace(/^import\s+.*$/gm, "");

        stripped = stripped.replace(/<[A-Z][a-zA-Z]*[^>]*\/>/g, "");

        stripped = stripped.replace(/<[A-Z][a-zA-Z]*[^>]*>/g, "");

        stripped = stripped.replace(/<\/[A-Z][a-zA-Z]*>/g, "");

        stripped = stripped.replace(/<br\s*\/?>/gi, "\n");

        stripped = stripped.replace(/\n{3,}/g, "\n\n");

        stripped = stripped.trim();


        const pagePath = filePath.replace(/^pages\//, "").replace(/\.mdx?$/,
        "");


        output = {
          file_path: filePath,
          file_name: fileName,
          page_path: pagePath,
          title: title || fileName,
          clean_content: stripped,
          content_length: stripped.length
        };
