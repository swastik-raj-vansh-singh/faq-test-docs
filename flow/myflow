  - nodeId: codeNode_build_file
    nodeType: codeNode
    nodeName: Build Updated File
    values:
      code: |-
        const faqs = {{codeNode_validate_faqs.output.faqs}};
        const faqValid = {{codeNode_validate_faqs.output.valid}};
        const ghFile = {{apiNode_get_file.output}};
        const fileSha = ghFile.sha || "";
        const base64Raw = (ghFile.content || "").replace(/\n/g, "");
        const originalMd = decodeURIComponent(escape(atob(base64Raw)));

        if (!faqValid) {
          output = {
            skip: true,
            skip_reason: "FAQ validation failed",
            base64_content: "",
            file_sha: fileSha,
            faq_count: 0,
            faqs: []
          };
        }
        else if (/##\s*(FAQ|Frequently Asked Questions)/i.test(originalMd)) {
          output = {
            skip: true,
            skip_reason: "FAQ section already exists in file",
            base64_content: "",
            file_sha: fileSha,
            faq_count: 0,
            faqs: []
          };
        }
        else {
          const itemsArray = faqs.map(function(faq) {
            return '  {\n    question: "' + faq.question.replace(/"/g, '\\"') + '",\n    answer: "' + faq.answer.replace(/"/g, '\\"') + '"\n  }';
          });

          let faqSection = '\nimport { FAQAccordion } from "@/components/FAQAccordion"\n\n';
          faqSection += "## Frequently Asked Questions\n\n";
          faqSection += "<FAQAccordion items={[\n";
          faqSection += itemsArray.join(",\n");
          faqSection += "\n]} />\n";

          const updatedMd = originalMd.trimEnd() + "\n" + faqSection;
          const base64Content = btoa(unescape(encodeURIComponent(updatedMd)));

          output = {
            skip: false,
            skip_reason: "",
            base64_content: base64Content,
            file_sha: fileSha,
            faq_count: faqs.length,
            faqs: faqs
          };
        }
